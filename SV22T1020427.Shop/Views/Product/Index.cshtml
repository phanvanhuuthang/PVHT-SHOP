@model SV22T1020427.Models.Catalog.ProductSearchInput
@{
    ViewData["Title"] = "Sản phẩm";
    int categoryID = Model?.CategoryID ?? 0;
    string searchValue = Model?.SearchValue ?? "";
    decimal minPrice = Model?.MinPrice ?? 0;
    decimal maxPrice = Model?.MaxPrice ?? 0;
}
<div class="container py-4">
    <div class="product-page">
        <div class="row g-4">
            <!-- Filter Sidebar -->
            <div class="col-lg-3">
                <div class="filter-card">
                    <div class="filter-title"><i class="bi bi-funnel me-2"></i>Bộ lọc tìm kiếm</div>
                    <form id="filterForm"
                          action="/Product/Search"
                          method="get"
                          data-target="searchResultContainer"
                          onsubmit="return paginationSearch(null, this, 1);">
                        <input type="hidden" name="page" value="@(Model?.Page > 0 ? Model.Page : 1)" />
                        <input type="hidden" name="pageSize" value="@(Model?.PageSize > 0 ? Model.PageSize : SV22T1020427.Shop.ApplicationContext.PageSize)" />

                        <!-- Search keyword -->
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Từ khóa</label>
                            <div class="input-group input-group-sm">
                                <input type="text" name="searchValue" class="form-control"
                                       placeholder="Tên sản phẩm..." value="@searchValue" />
                                <button class="btn btn-outline-secondary" type="submit">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Category -->
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Danh mục</label>
                            <select name="categoryID" class="form-select form-select-sm"
                                    onchange="return paginationSearch(null, this.form, 1);">
                                <option value="0" selected="@(categoryID == 0)">Tất cả danh mục</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var cat in (List<SV22T1020427.Models.Catalog.Category>)ViewBag.Categories)
                                    {
                                        <option value="@cat.CategoryID" selected="@(categoryID == cat.CategoryID)">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>

                        <!-- Price range -->
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Khoảng giá</label>
                            <div class="input-group input-group-sm mb-2">
                                <span class="input-group-text">Từ</span>
                                <input type="number" name="minPrice" class="form-control" placeholder="0"
                                       value="@(minPrice > 0 ? minPrice.ToString() : "")" min="0" step="1000" />
                                <span class="input-group-text">đ</span>
                            </div>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">Đến</span>
                                <input type="number" name="maxPrice" class="form-control" placeholder="∞"
                                       value="@(maxPrice > 0 ? maxPrice.ToString() : "")" min="0" step="1000" />
                                <span class="input-group-text">đ</span>
                            </div>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-sm">
                                <i class="bi bi-search me-1"></i>Tìm kiếm
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="col-lg-9">
                <div id="searchResultContainer">
                    <div class="text-center py-5 text-muted">
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <div>Đang tải sản phẩm...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast -->
<div class="toast-container">
    <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toastMsg">Đã thêm vào giỏ hàng</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `productID=${productId}&quantity=1`
            })
            .then(res => res.json())
            .then(data => {
                if (!data.success) return;

                document.getElementById('toastMsg').textContent = data.message;

                const badge = document.querySelector('.cart-badge');
                if (badge) {
                    badge.textContent = data.cartCount;
                    badge.classList.toggle('d-none', data.cartCount <= 0);
                }

                const toast = new bootstrap.Toast(document.getElementById('cartToast'));
                toast.show();
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('filterForm');
            if (form) {
                const currentPage = parseInt(form.querySelector('input[name="page"]')?.value || '1');
                paginationSearch(null, form, currentPage);
            }
        });
    </script>
}
