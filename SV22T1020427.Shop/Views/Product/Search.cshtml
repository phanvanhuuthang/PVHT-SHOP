@model SV22T1020427.Models.Common.PagedResult<SV22T1020427.Models.Catalog.Product>
@{
    Layout = null;
}

@if (Model == null)
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-search fs-1 d-block mb-3"></i>
        <h5>Không có dữ liệu</h5>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h6 class="mb-0 fw-bold">
                    <span>Tất cả sản phẩm</span>
            </h6>
            <small class="text-muted">Tìm thấy @Model.RowCount sản phẩm</small>
        </div>
    </div>

    @if (Model.DataItems != null && Model.DataItems.Count > 0)
    {
        <div class="row g-3">
            @foreach (var product in Model.DataItems)
            {
                <div class="col-6 col-md-4 col-xl-3">
                    <div class="product-card card h-100">
                        <a href="/Product/Details/@product.ProductID" class="text-decoration-none">
                            <div class="product-image-wrap">
                                @{
                                    string photo = product.Photo ?? "";
                                    string imageUrl = string.IsNullOrWhiteSpace(photo) || photo == "nophoto.png"
                                        ? ""
                                        : (photo.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                                            || photo.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                                            || photo.StartsWith("/")
                                                ? photo
                                                : $"/images/products/{photo}");
                                }

                                @if (!string.IsNullOrEmpty(imageUrl))
                                {
                                    <img src="@imageUrl" alt="@product.ProductName" class="card-img-top product-thumb"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div class="product-img-placeholder" style="display:none;">
                                        <i class="bi bi-image fs-1"></i>
                                    </div>
                                }
                                else
                                {
                                    <div class="product-img-placeholder">
                                        <i class="bi bi-image fs-1"></i>
                                    </div>
                                }
                            </div>
                        </a>

                        <div class="card-body d-flex flex-column p-2 p-md-3">
                            <a href="/Product/Details/@product.ProductID" class="text-decoration-none">
                                <p class="product-name">@product.ProductName</p>
                            </a>

                            <div class="product-meta">
                                <div class="price-box">
                                    <div class="product-price">@product.Price.ToString("N0")&nbsp;đ</div>
                                    <small class="product-unit">/@product.Unit</small>
                                </div>

                                <div class="product-actions">
                                    <a href="/Product/Details/@product.ProductID"
                                       class="btn btn-outline-primary btn-sm btn-detail"
                                       title="Chi tiết">
                                        <i class="bi bi-eye me-1"></i>Chi tiết
                                    </a>

                                    <button class="btn btn-add-cart btn-sm btn-outline-primary"
                                            onclick="addToCart(@product.ProductID)"
                                            title="Thêm vào giỏ">
                                        <i class="bi bi-cart-plus"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.PageCount > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link"
                           href="#"
                           onclick="return @(!Model.HasPreviousPage ? "false" : $"paginationSearch(event, document.getElementById('filterForm'), {Model.Page - 1})");">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>

                    @foreach (var pageItem in Model.GetDisplayPages())
                    {
                        if (pageItem.IsEllipsis)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        else
                        {
                            <li class="page-item @(pageItem.IsCurrent ? "active" : "")">
                                <a class="page-link"
                                   href="#"
                                   onclick="return @(pageItem.IsCurrent ? "false" : $"paginationSearch(event, document.getElementById('filterForm'), {pageItem.Page})");">
                                    @pageItem.Page
                                </a>
                            </li>
                        }
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link"
                           href="#"
                           onclick="return @(!Model.HasNextPage ? "false" : $"paginationSearch(event, document.getElementById('filterForm'), {Model.Page + 1})");">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-search fs-1 d-block mb-3"></i>
            <h5>Không tìm thấy sản phẩm nào</h5>
            <p>Hãy thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
        </div>
    }
}