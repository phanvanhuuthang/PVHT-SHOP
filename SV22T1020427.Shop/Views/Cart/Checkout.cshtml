@model List<SV22T1020427.Models.Sales.OrderDetailViewInfo>
@{
    ViewData["Title"] = "Đặt hàng";
    var customer = ViewBag.Customer as SV22T1020427.Models.Partner.Customer;
    decimal total = Model?.Sum(i => i.Quantity * i.SalePrice) ?? 0;
}

<div class="container py-4">
    <h4 class="fw-bold mb-4"><i class="bi bi-bag-check me-2 text-primary"></i>Xác nhận đặt hàng</h4>

    <!-- Progress Steps -->
    <div class="d-flex align-items-center mb-4">
        <div class="d-flex align-items-center">
            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center" style="width:32px;height:32px;">
                <i class="bi bi-check-lg fs-6"></i>
            </div>
            <span class="ms-2 fw-semibold text-success">Giỏ hàng</span>
        </div>
        <div class="flex-grow-1 border-top mx-3"></div>
        <div class="d-flex align-items-center">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:32px;height:32px;">2</div>
            <span class="ms-2 fw-semibold text-primary">Đặt hàng</span>
        </div>
        <div class="flex-grow-1 border-top mx-3"></div>
        <div class="d-flex align-items-center">
            <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center" style="width:32px;height:32px;">3</div>
            <span class="ms-2 text-muted">Hoàn tất</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Checkout Form -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-geo-alt me-2 text-primary"></i>Địa chỉ giao hàng</h6>
                </div>
                <div class="card-body p-4">
                    @Html.ValidationMessage("Error", new { @class = "alert alert-danger d-block mb-3" })

                    <form action="/Cart/Checkout" method="post" id="checkoutForm">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Người nhận hàng</label>
                            <input type="text" class="form-control bg-light" value="@customer?.CustomerName" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Số điện thoại</label>
                            <input type="text" class="form-control bg-light" value="@customer?.Phone" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Tỉnh/Thành phố giao hàng <span class="text-danger">*</span></label>
                            <input type="text" name="deliveryProvince" class="form-control"
                                   placeholder="Nhập tỉnh/thành phố..." value="@customer?.Province" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <input type="text" name="deliveryAddress" class="form-control"
                                   placeholder="Số nhà, tên đường, phường/xã, quận/huyện..." value="@customer?.Address" required />
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-credit-card me-2 text-primary"></i>Phương thức thanh toán</h6>
                </div>
                <div class="card-body p-4">
                    <div class="form-check p-3 border rounded-3 mb-2 bg-light">
                        <input class="form-check-input" type="radio" name="paymentMethod" value="cod" id="payCOD" checked />
                        <label class="form-check-label fw-semibold ms-2" for="payCOD">
                            <i class="bi bi-cash-coin text-success me-2"></i>Thanh toán khi nhận hàng (COD)
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm sticky-top" style="top:80px;">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2 text-primary"></i>Sản phẩm đặt mua (@(Model?.Count ?? 0))</h6>
                </div>
                <div class="card-body p-3">
                    @if (Model != null)
                    {
                        <div class="overflow-auto" style="max-height:300px;">
                            @foreach (var item in Model)
                            {
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    @if (!string.IsNullOrWhiteSpace(item.Photo) && item.Photo != "nophoto.png")
                                    {
                                        <img src="/images/products/@item.Photo" class="rounded" style="width:48px;height:48px;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div class="rounded bg-light d-flex align-items-center justify-content-center text-muted"
                                             style="width:48px;height:48px;">
                                            <i class="bi bi-image"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1">
                                        <div class="small fw-semibold">@item.ProductName</div>
                                        <small class="text-muted">x@item.Quantity | @item.SalePrice.ToString("N0") đ</small>
                                    </div>
                                    <div class="fw-semibold small text-danger">
                                        @((item.Quantity * item.SalePrice).ToString("N0")) đ
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Tạm tính:</span>
                        <span>@total.ToString("N0") đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí vận chuyển:</span>
                        <span class="text-success fw-semibold">Miễn phí</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 pt-2 border-top">
                        <strong class="fs-6">Tổng thanh toán:</strong>
                        <strong class="text-danger fs-5">@total.ToString("N0") đ</strong>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" form="checkoutForm" class="btn btn-success btn-lg">
                            <i class="bi bi-bag-check me-2"></i>Xác nhận đặt hàng
                        </button>
                        <a href="/Cart/Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Quay lại giỏ hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
