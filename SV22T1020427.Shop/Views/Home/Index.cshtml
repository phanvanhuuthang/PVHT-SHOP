    }

    .shop-header #navMenu .nav-link.active i,
    .shop-header #navMenu .nav-link[aria-current="page"] i {
        color: #0a4fb3 !important;
        text-shadow: none !important;
    }

    /* Icon bên phải (cart/user) */
    .shop-header .btn-icon i,
    .shop-header .navbar-toggler i {
        color: #ffffff !important;
        font-size: 1.2rem !important;
        text-shadow: 0 1px 1px rgba(0, 0, 0, 0.25);
    }

    .shop-header .btn-outline-primary {
        color: #ffffff !important;
        border-color: rgba(255, 255, 255, 0.85) !important;
    }

    .shop-header .btn-outline-primary:hover {
