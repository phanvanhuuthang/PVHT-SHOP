            -webkit-box-orient: vertical;
        }

        .product-price {
            color: #dc3545;   /* đỏ dễ nhìn */
            font-weight: 700; /* đậm luôn giá */
        }

    .hero-carousel-wrap {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .hero-carousel {
        width: 100%;
        max-width: 360px; /* thu nhỏ */
