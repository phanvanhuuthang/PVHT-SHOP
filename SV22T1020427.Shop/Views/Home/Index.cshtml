            box-shadow: 0 10px 24px rgba(59, 130, 246, 0.16);
        }

        .product-image-wrap {
            aspect-ratio: 4 / 3;
            background: #f6f8fc;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid #e7edf6;
        }

        .product-thumb {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 8px;
        }

        .product-img-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9aa4b2;
            background: #f6f8fc;
        }

        .product-name {
            min-height: 52px;
            line-height: 1.4;
