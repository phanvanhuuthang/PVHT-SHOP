@model OrderViewInfo
@{
    ViewData["Title"] = $"Đơn hàng #{Model.OrderID}";
    var details = ViewBag.Details as List<SV22T1020427.Models.Sales.OrderDetailViewInfo> ?? new List<SV22T1020427.Models.Sales.OrderDetailViewInfo>();

    Func<string?, string> getImageUrl = photo =>
    {
        if (string.IsNullOrWhiteSpace(photo) || photo == "nophoto.png")
            return "";

        if (photo.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || photo.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            || photo.StartsWith("/"))
            return photo;

        return $"/images/products/{photo}";
    };

    string badgeClass = Model.Status switch
    {
        SV22T1020427.Models.Sales.OrderStatusEnum.New => "bg-secondary",
        SV22T1020427.Models.Sales.OrderStatusEnum.Accepted => "bg-primary",
        SV22T1020427.Models.Sales.OrderStatusEnum.Shipping => "bg-warning text-dark",
        SV22T1020427.Models.Sales.OrderStatusEnum.Completed => "bg-success",
        SV22T1020427.Models.Sales.OrderStatusEnum.Cancelled => "bg-danger",
        SV22T1020427.Models.Sales.OrderStatusEnum.Rejected => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="container py-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item"><a href="/Order/Index">Đơn hàng của tôi</a></li>
            <li class="breadcrumb-item active">#@Model.OrderID</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-receipt me-2 text-primary"></i>Chi tiết đơn hàng #@Model.OrderID
        </h4>
        <span class="badge @badgeClass px-3 py-2 fs-6">@Model.Status.GetDescription()</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Order Info & Timeline -->
        <div class="col-lg-4">
            <!-- Order Info -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2 text-primary"></i>Thông tin đơn hàng</h6>
                </div>
                <div class="card-body p-3">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted small">Mã đơn:</td>
                            <td class="fw-semibold">#@Model.OrderID</td>
                        </tr>
                        <tr>
                            <td class="text-muted small">Ngày đặt:</td>
                            <td class="small">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                        @if (Model.AcceptTime.HasValue)
                        {
                            <tr>
                                <td class="text-muted small">Ngày duyệt:</td>
                                <td class="small">@Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                        @if (Model.ShippedTime.HasValue)
                        {
                            <tr>
                                <td class="text-muted small">Ngày giao:</td>
                                <td class="small">@Model.ShippedTime.Value.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                        @if (Model.FinishedTime.HasValue)
                        {
                            <tr>
                                <td class="text-muted small">Ngày hoàn tất:</td>
                                <td class="small">@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>

            <!-- Delivery Info -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-truck me-2 text-primary"></i>Thông tin giao hàng</h6>
                </div>
                <div class="card-body p-3">
                    <p class="mb-1 fw-semibold">@Model.CustomerName</p>
                    <p class="mb-1 small text-muted">@Model.CustomerPhone</p>
                    <p class="mb-0 small text-muted">
                        <i class="bi bi-geo-alt me-1"></i>@Model.DeliveryAddress, @Model.DeliveryProvince
                    </p>
                    @if (!string.IsNullOrEmpty(Model.ShipperName))
                    {
                        <hr class="my-2" />
                        <p class="mb-0 small">
                            <strong>Người giao:</strong> @Model.ShipperName (@Model.ShipperPhone)
                        </p>
                    }
                </div>
            </div>

            <!-- Order Timeline -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Tiến trình đơn hàng</h6>
                </div>
                <div class="card-body p-3">
                    <ul class="order-timeline">
                        @{
                            bool isNew = Model.Status >= SV22T1020427.Models.Sales.OrderStatusEnum.New;
                            bool isAccepted = Model.Status >= SV22T1020427.Models.Sales.OrderStatusEnum.Accepted;
                            bool isShipping = Model.Status >= SV22T1020427.Models.Sales.OrderStatusEnum.Shipping;
                            bool isCompleted = Model.Status == SV22T1020427.Models.Sales.OrderStatusEnum.Completed;
                            bool isCancelled = Model.Status == SV22T1020427.Models.Sales.OrderStatusEnum.Cancelled
                                            || Model.Status == SV22T1020427.Models.Sales.OrderStatusEnum.Rejected;
                        }
                        <li class="@(isNew ? "done" : "")">
                            <div class="dot"></div>
                            <strong class="small">Đặt hàng thành công</strong>
                            <div class="text-muted" style="font-size:0.8rem;">@Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</div>
                        </li>
                        <li class="@(isAccepted ? "done" : (isCancelled ? "" : ""))">
                            <div class="dot"></div>
                            <strong class="small">Đã xác nhận đơn hàng</strong>
                            @if (Model.AcceptTime.HasValue)
                            {
                                <div class="text-muted" style="font-size:0.8rem;">@Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            }
                        </li>
                        <li class="@(isShipping ? "done" : "")">
                            <div class="dot"></div>
                            <strong class="small">Đang giao hàng</strong>
                            @if (Model.ShippedTime.HasValue)
                            {
                                <div class="text-muted" style="font-size:0.8rem;">@Model.ShippedTime.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            }
                        </li>
                        <li class="@(isCompleted ? "done" : "")">
                            <div class="dot"></div>
                            <strong class="small">Giao hàng thành công</strong>
                            @if (Model.FinishedTime.HasValue && isCompleted)
                            {
                                <div class="text-muted" style="font-size:0.8rem;">@Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</div>
                            }
                        </li>
                        @if (isCancelled)
                        {
                            <li>
                                <div class="dot" style="background:#dc3545;box-shadow:0 0 0 2px #dc3545;"></div>
                                <strong class="small text-danger">@Model.Status.GetDescription()</strong>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Products in Order -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Sản phẩm trong đơn hàng</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table cart-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3" style="width:50%">Sản phẩm</th>
                                <th class="text-center">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end pe-3">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in details)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-3">
                                            @{
                                                var itemImageUrl = getImageUrl(item.Photo);
                                            }
                                            @if (!string.IsNullOrEmpty(itemImageUrl))
                                            {
                                                <img src="@itemImageUrl" class="cart-item-img" alt="@item.ProductName"
                                                     onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                                <div class="cart-item-img bg-light d-flex align-items-center justify-content-center text-muted rounded" style="display:none;">
                                                    <i class="bi bi-image"></i>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="cart-item-img bg-light d-flex align-items-center justify-content-center text-muted rounded">
                                                    <i class="bi bi-image"></i>
                                                </div>
                                            }
                                            <div>
                                                <a href="/Product/Details/@item.ProductID" class="fw-semibold text-dark text-decoration-none">
                                                    @item.ProductName
                                                </a>
                                                <small class="text-muted d-block">@item.Unit</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center small money">@item.SalePrice.ToString("N0")&nbsp;đ</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end pe-3 fw-semibold text-danger money">@((item.Quantity * item.SalePrice).ToString("N0"))&nbsp;đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="border-top">
                                <td colspan="3" class="text-end fw-bold pe-3 py-3">Tổng cộng:</td>
                                <td class="text-end pe-3 py-3">
                                    <strong class="text-danger fs-5 money">@Model.SumOfPrice.ToString("N0")&nbsp;đ</strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="card-footer bg-white border-0 d-flex gap-2 justify-content-end py-3 px-3">
                    <a href="/Order/Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left me-1"></i>Quay lại
                    </a>
                    <a href="/Product/Index" class="btn btn-primary btn-sm">
                        <i class="bi bi-cart me-1"></i>Mua thêm
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .cart-table {
            table-layout: fixed;
            width: 100%;
        }

        .money {
            white-space: nowrap;
        }

        .cart-table th,
        .cart-table td {
            vertical-align: middle;
        }

        .cart-item-img {
            width: 72px;
            height: 72px;
            min-width: 72px;
            max-width: 72px;
            object-fit: cover;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            background: #fff;
            display: block;
        }

        .cart-table td:first-child .d-flex {
            min-width: 0;
        }

        .cart-table td:first-child a {
            display: -webkit-box;
            overflow: hidden;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            word-break: break-word;
        }

        .card-body.p-0 {
            overflow-x: auto;
        }

        @@media (max-width: 768px) {
            .cart-item-img {
                width: 60px;
                height: 60px;
                min-width: 60px;
                max-width: 60px;
            }
        }
    </style>
}
