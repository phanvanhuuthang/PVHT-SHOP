@model List<SV22T1020427.Models.Sales.OrderViewInfo>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var status = (SV22T1020427.Models.Sales.OrderStatusEnum)(ViewBag.Status ?? 0);
}

<div class="container py-4 my-orders-page">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-bag me-2 text-primary"></i>Đơn hàng của tôi
        </h4>
    </div>

    <ul class="nav nav-pills order-filter mb-4">
        <li class="nav-item">
            <a class="nav-link @(status == SV22T1020427.Models.Sales.OrderStatusEnum.All ? "active" : "")" href="/Order/Index?status=0">Tất cả</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(status == SV22T1020427.Models.Sales.OrderStatusEnum.New ? "active" : "")" href="/Order/Index?status=1">Chờ xử lý</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(status == SV22T1020427.Models.Sales.OrderStatusEnum.Accepted ? "active" : "")" href="/Order/Index?status=2">Đã duyệt</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(status == SV22T1020427.Models.Sales.OrderStatusEnum.Shipping ? "active" : "")" href="/Order/Index?status=3">Đang giao</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(status == SV22T1020427.Models.Sales.OrderStatusEnum.Completed ? "active" : "")" href="/Order/Index?status=4">Hoàn tất</a>
        </li>
    </ul>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5 text-muted bg-white rounded-4 border border-primary-subtle">
            <i class="bi bi-bag-x fs-1 d-block mb-3 text-primary"></i>
            <h5>Chưa có đơn hàng nào</h5>
            <p>Hãy mua sắm để tạo đơn hàng đầu tiên của bạn.</p>
            <a href="/Product/Index" class="btn btn-primary px-4">
                <i class="bi bi-grid me-2"></i>Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var order in Model)
            {
                string badgeClass = order.Status switch
                {
                    SV22T1020427.Models.Sales.OrderStatusEnum.New => "badge-status badge-status-new",
                    SV22T1020427.Models.Sales.OrderStatusEnum.Accepted => "badge-status badge-status-accepted",
                    SV22T1020427.Models.Sales.OrderStatusEnum.Shipping => "badge-status badge-status-shipping",
                    SV22T1020427.Models.Sales.OrderStatusEnum.Completed => "badge-status badge-status-completed",
                    SV22T1020427.Models.Sales.OrderStatusEnum.Cancelled => "badge-status badge-status-cancelled",
                    SV22T1020427.Models.Sales.OrderStatusEnum.Rejected => "badge-status badge-status-cancelled",
                    _ => "badge-status badge-status-new"
                };

                <div class="card order-card">
                    <div class="card-header order-card-header d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center flex-wrap gap-3">
                            <span class="fw-bold text-primary order-id">#@order.OrderID</span>
                            <span class="text-muted small">
                                <i class="bi bi-clock me-1"></i>@order.OrderTime.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>
                        <span class="@badgeClass">@order.Status.GetDescription()</span>
                    </div>

                    <div class="card-body order-card-body">
                        <div class="row g-3 align-items-center">
                            <div class="col-md-7">
                                <small class="text-muted d-block mb-1">
                                    <i class="bi bi-geo-alt me-1"></i>@order.DeliveryProvince - @order.DeliveryAddress
                                </small>
                                @if (!string.IsNullOrEmpty(order.ShipperName))
                                {
                                    <small class="text-muted d-block">
                                        <i class="bi bi-truck me-1"></i>Người giao: @order.ShipperName (@order.ShipperPhone)
                                    </small>
                                }
                            </div>

                            <div class="col-md-5 text-md-end">
                                <div class="fw-bold text-primary fs-4 mb-2">@order.SumOfPrice.ToString("N0")&nbsp;đ</div>
                                <a href="/Order/Details/@order.OrderID" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye me-1"></i>Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

