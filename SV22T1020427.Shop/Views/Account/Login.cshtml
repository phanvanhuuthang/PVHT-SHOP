@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - TNP Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />
    <style>
        body {
            min-height: 100vh;
            margin: 0;
            display: flex;
            align-items: center;
            background:
                linear-gradient(135deg, #eef4ff 0%, #f6f9ff 50%, #eef7ff 100%);
            color: #1f2937;
        }

        .login-wrap {
            width: 100%;
            padding: 24px 12px;
        }

        .auth-card {
            max-width: 440px;
            margin: 0 auto;
            border: 0;
            border-radius: 16px;
            overflow: hidden;
            background: #ffffff;
            box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12);
        }

        .auth-card .card-header {
            background:
                linear-gradient(135deg, #0d6efd 0%, #2b7fff 100%);
            color: #fff;
            border: 0;
        }

        .auth-card .card-header p {
            color: rgba(255, 255, 255, 0.9);
        }

        .input-group-text {
            background: #f8fafc;
            border-right: 0;
        }

        .form-control {
            border-left: 0;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #86b7fe;
        }

        .input-group:focus-within .input-group-text {
            border-color: #86b7fe;
            color: #0d6efd;
        }

        .btn-login {
            border-radius: 10px;
            font-weight: 600;
            padding-top: 10px;
            padding-bottom: 10px;
        }

        .register-link a {
            text-decoration: none;
        }

        .register-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>
    <div class="container login-wrap">
        <div class="auth-card card">
            <div class="card-header text-center py-4">
                <a href="/" class="text-white text-decoration-none">
                    <i class="bi bi-shop fs-2 d-block mb-1"></i>
                    <h4 class="mb-0 fw-bold">TNP Shop</h4>
                </a>
                <p class="mb-0 mt-1">Đăng nhập tài khoản</p>
            </div>

            <div class="card-body p-4">
                @if (TempData["SuccessMessage"] != null)
                {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                </div>
                }

                <form action="/Account/Login" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="username" class="form-control"
                                placeholder="email@example.com" value="@ViewBag.Username"
                                required autofocus />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" class="form-control"
                                placeholder="Nhập mật khẩu" required />
                        </div>
                    </div>

                    @Html.ValidationMessage("Error", new { @class = "text-danger small d-block mb-3" })

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-login">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </button>
                    </div>
                </form>

                <hr>
                <p class="text-center mb-0 text-muted small register-link">
                    Chưa có tài khoản?
                    <a href="/Account/Register" class="fw-semibold">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
