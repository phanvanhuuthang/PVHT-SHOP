<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TNP Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shop.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

</head>
<body>
    @{
        var displayName = User.GetUserData()?.DisplayName ?? "";
        var userName = displayName;

        if (!string.IsNullOrWhiteSpace(displayName)
        && displayName.EndsWith("@gmail.com", StringComparison.OrdinalIgnoreCase))
        {
            var atIndex = displayName.IndexOf('@');
            if (atIndex > 0)
            {
                userName = displayName.Substring(0, atIndex);
            }
        }
    }

    <!-- Top bar -->
    <div class="top-bar py-1 d-none d-md-block">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted"><i class="bi bi-telephone me-1"></i>1900-1234 &nbsp;|&nbsp; <i class="bi bi-envelope me-1"></i>support@tnpshop.vn</small>
                <small>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="text-muted">Xin chào, <strong>@userName</strong></span>
                    }
                    else
                    {
                        <a href="/Account/Login" class="text-muted me-2"><i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập</a>
                        <a href="/Account/Register" class="text-muted"><i class="bi bi-person-plus me-1"></i>Đăng ký</a>
                    }
                </small>
            </div>
        </div>
    </div>

    <!-- Main Header -->
    <header class="shop-header sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop me-2"></i><strong>TNP</strong> Shop
                </a>

                <!-- Search Bar (Desktop) -->
                <div class="search-bar d-none d-lg-flex flex-grow-1 mx-4">
                    <form action="/Product/Index" method="get" class="d-flex w-100">
                        <div class="input-group">
                            <input type="text" name="searchValue" class="form-control search-input"
                                   placeholder="Tìm kiếm sản phẩm..." value="@ViewBag.SearchValue" autocomplete="off" />
                            <button class="btn btn-search" type="submit" aria-label="Tìm kiếm">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Right icons -->
                <div class="header-actions d-flex align-items-center gap-2">
                    <!-- Cart -->
                    <a href="/Cart/Index" class="btn btn-icon position-relative">
                        <i class="bi bi-cart3 fs-5"></i>
                        @{
                            int cartCount = SV22T1020427.Shop.ShoppingCartHelper.GetCartItemCount();
                        }
                        <span class="badge bg-danger cart-badge @(cartCount > 0 ? "" : "d-none")">@cartCount</span>
                    </a>

                    <!-- User Menu -->
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <button class="btn btn-icon dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">@userName</h6></li>
                                <li><a class="dropdown-item" href="/Account/Profile"><i class="bi bi-person me-2"></i>Thông tin cá nhân</a></li>
                                <li><a class="dropdown-item" href="/Order/Index"><i class="bi bi-bag me-2"></i>Đơn hàng của tôi</a></li>
                                <li><a class="dropdown-item" href="/Account/ChangePassword"><i class="bi bi-key me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-outline-primary btn-sm d-none d-md-inline-flex align-items-center gap-1">
                            <i class="bi bi-person"></i> Đăng nhập
                        </a>
                    }

                    <!-- Mobile toggler -->
                    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                </div>

                <!-- Nav Menu -->
                <div class="collapse navbar-collapse" id="navMenu">
                    <!-- Mobile Search -->
                    <div class="d-lg-none my-2">
                        <form action="/Product/Index" method="get" class="d-flex">
                            <input type="text" name="searchValue" class="form-control me-2" placeholder="Tìm kiếm..." value="@ViewBag.SearchValue" />
                            <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                        </form>
                    </div>
                    <ul class="navbar-nav me-auto mt-2 mt-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index"><i class="bi bi-grid me-1"></i>Sản phẩm</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="Index"><i class="bi bi-bag me-1"></i>Đơn hàng</a>
                            </li>
                            <li class="nav-item d-lg-none">
                                <a class="nav-link" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-1"></i>Tài khoản</a>
                            </li>
                            <li class="nav-item d-lg-none">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-1"></i>Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-lg-none">
                                <a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập</a>
                            </li>
                            <li class="nav-item d-lg-none">
                                <a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Category Nav Bar -->
    <div class="category-bar d-none d-lg-block">
        <div class="container">
            <div class="category-list">
                <a href="/Product/Index" class="cat-link @(ViewBag.CategoryID == 0 || ViewBag.CategoryID == null ? "active" : "")">
                    <i class="bi bi-grid-3x3-gap me-1"></i>Tất cả
                </a>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in (List<SV22T1020427.Models.Catalog.Category>)ViewBag.Categories)
                    {
                        <a href="/Product/Index?categoryID=@cat.CategoryID"
                           class="cat-link @(ViewBag.CategoryID?.ToString() == cat.CategoryID.ToString() ? "active" : "")">
                            @cat.CategoryName
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <main class="main-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="shop-footer mt-5">
        <div class="container">
            <div class="row py-4">
                <div class="col-md-4 mb-3">
                    <h6 class="fw-bold"><i class="bi bi-shop me-2"></i>TNP Shop</h6>
                    <p class="text-muted small">Cửa hàng trực tuyến uy tín, chất lượng cao với nhiều sản phẩm đa dạng.</p>
                </div>
                <div class="col-md-2 mb-3">
                    <h6 class="fw-bold">Sản phẩm</h6>
                    <ul class="list-unstyled small text-muted">
                        <li><a href="/Product/Index" class="footer-link">Tất cả sản phẩm</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="fw-bold">Tài khoản</h6>
                    <ul class="list-unstyled small text-muted">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a href="/Account/Profile" class="footer-link">Thông tin cá nhân</a></li>
                            <li><a href="/Order/Index" class="footer-link">Đơn hàng của tôi</a></li>
                        }
                        else
                        {
                            <li><a href="/Account/Login" class="footer-link">Đăng nhập</a></li>
                            <li><a href="/Account/Register" class="footer-link">Đăng ký</a></li>
                        }
                        <li><a href="/Cart/Index" class="footer-link">Giỏ hàng</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="fw-bold">Liên hệ</h6>
                    <ul class="list-unstyled small text-muted">
                        <li><i class="bi bi-telephone me-2"></i>1900-1234</li>
                        <li><i class="bi bi-envelope me-2"></i>support@tnpshop.vn</li>
                        <li><i class="bi bi-geo-alt me-2"></i>TP. Hồ Chí Minh</li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary">
            <div class="text-center text-muted small py-2">
                &copy; @DateTime.Now.Year TNP Shop. Tất cả quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


