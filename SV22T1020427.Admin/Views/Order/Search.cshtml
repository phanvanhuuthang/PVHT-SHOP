@using System.Globalization
@using SV22T1020427.Admin
@using SV22T1020427.Admin.Models
@using SV22T1020427.Models.Catalog
@using SV22T1020427.Models.Common
@using SV22T1020427.Models.HR
@using SV22T1020427.Models.Partner
@using SV22T1020427.Models.Sales
@using SV22T1020427.Models.Security
@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}
<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.OrderTime</td>
                        <td>@item.CustomerName</td>
                        <td>@item.CustomerPhone</td>
                        <td>@item.AcceptTime</td>
                        <td>@item.EmployeeName</td>
                        <td class="text-end">@item.SumOfPrice.ToString("N0", new CultureInfo("vi-VN"))</td>
                        <td class="text-center">
                            @if (item.Status == (OrderStatusEnum)1)
                            {
                                <span class="badge bg-success">Đang chờ duyệt</span>
                            }
                            else if (item.Status == (OrderStatusEnum)(-2))
                            {
                                <span class="badge bg-danger">Bị từ chối</span>
                            }
                            else if (item.Status == (OrderStatusEnum)(-1))
                            {
                                <span class="badge bg-secondary">Bị hủy</span>
                            }
                            else if (item.Status == (OrderStatusEnum)2)
                            {
                                <span class="badge bg-info text-dark">Đã duyệt</span>
                            }
                            else if (item.Status == (OrderStatusEnum)3)
                            {
                                <span class="badge bg-primary">Đang giao hàng</span>
                            }
                            else if (item.Status == (OrderStatusEnum)4)
                            {
                                <span class="badge bg-success">Hoàn tất</span>
                            }
                      
                            
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        <!-- Pagination -->
        <ul class="pagination justify-content-center">
            @foreach (var p in Model.GetDisplayPages())
            {
                if (p.IsCurrent)
                {
                    <li class="page-item active">
                        <a class="page-link">@p.Page</a>
                    </li>
                }
                else if (p.IsEllipsis)
                {
                    <li class="page-item">
                        <a class="page-link">...</a>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;"
                           onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">
                            @p.Page
                        </a>
                    </li>
                }
            }



        </ul>
    </div>
</div>
