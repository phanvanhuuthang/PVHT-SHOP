@using System.Globalization
@using SV22T1020427.Admin
@using SV22T1020427.Admin.Models
@using SV22T1020427.Models.Catalog
@using SV22T1020427.Models.Common
@using SV22T1020427.Models.HR
@using SV22T1020427.Models.Partner
@using SV22T1020427.Models.Sales
@using SV22T1020427.Models.Security
@model PagedResult<Product>
@{
    Layout = null;
}
<!-- Danh sách mặt hàng -->
@foreach (var item in Model.DataItems)
{
    <form method="post" class="border rounded p-2 mb-2" onsubmit="addCartItem(event,this)">
        <strong>@item.ProductName</strong>
        <input type="hidden" name="productId" value="@item.ProductID" />
        <div class="row mt-2 align-items-start">
            <div class="col-4">
                <img src="~/images/products/@item.Photo"
                     class="img-thumbnail w-100"
                     style="max-height:100px; object-fit:cover;"
                     alt="@item.ProductName" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Giá</label>
                        <input type="hidden" name="price" value="@item.Price" />
                        <input class="form-control form-control-sm money-input"
                               value="@item.Price.ToString("N0", new CultureInfo("vi-VN"))"
                               onfocus="unformatPrice(this)"
                               onblur="formatPrice(this)" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number" name="quantity"
                               min="1"
                               value="1"
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}

<ul class="pagination justify-content-between mb-0">
    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
        <a class="page-link" href="javascript:;"
           onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
            <i class="bi bi-chevron-left"></i>
        </a>
    </li>
    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
        <a class="page-link" href="javascript:;"
           onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
            <i class="bi bi-chevron-right"></i>
        </a>
    </li>
</ul>

