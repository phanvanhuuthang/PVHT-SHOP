@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="formSearch"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <div class="input-group">
                        <input type="hidden" asp-for="PageSize" />
                        <input type="hidden" asp-for="CategoryID" />
                        <input type="hidden" asp-for="SupplierID" />
                        <input type="hidden" asp-for="MinPrice" />
                        <input type="hidden" asp-for="MaxPrice" />
                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />

                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
                <!--Danh sách mặt hàng-->
                <div id="searchResult">

                </div>
                
            </div>

            
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div class="row">
            <div class="col-12" id="cart">
                
            </div>
        </div>
        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerID" asp-items="await SelectListHelper.Customers()">
                                        
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select"
                                        name="province" asp-items="await SelectListHelper.Provinces()"></select>
                                   
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address" rows="2"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });
        // lấy và hiển thị giỏ hàng
        function showCart() 
        {
            fetch("/Order/ShowCart", { method: "GET" })
                .then(response => response.text())
                .then(html => {
                    const container = document.getElementById("cart");
                    if (container) {
                        container.innerHTML = html;
                    }
                });
        }
        //Bổ sung mặt hàng vào giỏ
        function addCartItem(event, form) 
        {
            event.preventDefault();

            const formData = new FormData(form);

            fetch("/Order/AddCartItem", {
                method: "POST",
                body: formData
            })
                .then(response => response.json())
                .then(result => {
                    if (result.code === 0) {
                        alert(result.message);
                        return;
                    }
                    showCart();
                })
                .catch(() => {
                    alert("Không thể thêm vào giỏ hàng. Vui lòng thử lại.");
                });
        }
        // Xóa mặt hàng trong giỏ
         function deleteCartItem(productID) 
        {
            fetch(`/Order/DeleteCartItem?productId=${productID}`, { method: "POST" })
                .then(() => showCart())
                .catch(() => {
                    alert("Không thể xóa mặt hàng. Vui lòng thử lại.");
                });
        }
        function clearCart() {
            fetch("/Order/ClearCart", { method: "POST" })
                .then(() => showCart())
                .catch(() => {
                    alert("Không thể xóa giỏ hàng. Vui lòng thử lại.");
                });
        }
        function updateCartItem(event, form) 
        {
            event.preventDefault();

            const formData = new FormData(form);

            fetch("/Order/UpdateCartItem", {
                method: "POST",
                body: formData
            })
                .then(response => response.json())
                .then(result => {
                    if (result.code === 0) {
                        alert(result.message);
                        return;
                    }

                    showCart();

                    const modalEl = document.getElementById("dialogModal");
                    if (modalEl) {
                        const modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                        modal.hide();
                    }
                })
                .catch(() => {
                    alert("Không thể cập nhật giỏ hàng. Vui lòng thử lại.");
                });
        }
         function createOrder(event, form) {
            event.preventDefault();

            const formData = new FormData(form);

            fetch("/Order/CreateOrder", {
                method: "POST",
                body: formData
            })
                .then(response => response.json())
                .then(result => {
                    if (result.code === 0) {
                        alert(result.message);
                        return;
                    }
                    window.location.href = `/Order/Detail/${result.code}`;
                })
                .catch(() => {
                    alert("Không thể tạo đơn hàng. Vui lòng thử lại.");
                });
        }
      
        function unformatPrice(input) {
            const hidden = input.previousElementSibling;
            if (hidden) input.value = hidden.value;
        }

        function formatPrice(input) {
            const raw = input.value.replace(/[^\d]/g, "");
            const value = raw ? parseInt(raw, 10) : 0;

            const hidden = input.previousElementSibling;
            if (hidden) hidden.value = value;

            input.value = value.toLocaleString("vi-VN");
        }
    
    </script>
}