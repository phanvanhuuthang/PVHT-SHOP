@model Employee
@{
    ViewBag.Title = "Phân quyền nhân viên";
    var selectedRoles = (ViewBag.SelectedRoles as HashSet<string>) ?? new HashSet<string>();
}

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EmployeeID" />

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success">@ViewBag.SuccessMessage</div>
                    }
                    else
                    {
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    }

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield-lock me-1"></i>
                            Danh sách quyền
                        </legend>

                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width:60px;" class="text-center">Chọn</th>
                                        <th>Tên quyền</th>
                                        <th>Mô tả quyền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var role in ViewBag.RoleOptions)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="roles"
                                                       value="@role.Value"
                                                       @(selectedRoles.Contains(role.Value) ? "checked" : "") />
                                            </td>
                                            <td>@role.Name</td>
                                            <td>@role.Description</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </fieldset>
                </form>
            </div>
        </div>
    </div>
</div>
