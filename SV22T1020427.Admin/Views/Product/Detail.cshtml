@{
    ViewBag.Title = "Chi tiết mặt hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-12 offset-md-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-box-seam"></i> Chi tiết mặt hàng
                </h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <h4 class="mb-3">iPhone 15 Pro Max 256GB</h4>

                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width: 30%;">Loại hàng:</th>
                                    <td>Điện thoại di động</td>
                                </tr>
                                <tr>
                                    <th>Nhà cung cấp:</th>
                                    <td>Công ty TNHH ABC</td>
                                </tr>
                                <tr>
                                    <th>Đơn vị tính:</th>
                                    <td>Chiếc</td>
                                </tr>
                                <tr>
                                    <th>Giá bán:</th>
                                    <td class="text-danger fw-bold">29.990.000 ₫</td>
                                </tr>
                                <tr>
                                    <th>Tồn kho:</th>
                                    <td>150 chiếc</td>
                                </tr>
                                <tr>
                                    <th>Trạng thái:</th>
                                    <td>
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Đang bán
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="mb-3">
                            <h5>Mô tả sản phẩm:</h5>
                            <p class="text-muted">
                                iPhone 15 Pro Max với chip A17 Pro mạnh mẽ, camera 48MP, màn hình Super Retina XDR 6.7 inch,
                                khung Titan cao cấp. Hỗ trợ 5G, pin lâu, sạc nhanh.
                            </p>
                        </div>

                        <div class="btn-group" role="group">
                            <a href="~/Product/Edit/1" class="btn btn-primary">
                                <i class="bi bi-pencil"></i> Chỉnh sửa
                            </a>
                            <a href="~/Product/ListAttribute/1" class="btn btn-info">
                                <i class="bi bi-sliders"></i> Thuộc tính
                            </a>
                            <a href="~/Product/ListPhotos/1" class="btn btn-warning">
                                <i class="bi bi-images"></i> Hình ảnh
                            </a>
                            <a href="~/Product/Delete/1" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="text-center">
                            <img src="~/images/products/iphone15promax.jpg" alt="Product" class="img-thumbnail" style="width: 100%; max-width: 300px;">
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <a href="~/Product/Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
            </div>
        </div>
    </div>
</div>